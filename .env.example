# Copy this file to ".env" and fill in your keys.
# cp .env.example .env

# --- Spotify Developer app (https://developer.spotify.com/dashboard) ---
# Create an app, then copy its Client ID + Secret.
# Add the redirect URI below to the app's settings ("Redirect URIs").
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Last.fm API (https://www.last.fm/api/account/create) ---
# Free. Only the API key is needed for read-only tag lookups.
LASTFM_API_KEY=

# --- Optional: Anthropic / Claude ---
# Used by the optional LLM refinement pass (USE_LLM in config.py) AND by the
# genre-specification classifier (`cli.py genre-classify`).
ANTHROPIC_API_KEY=

# --- Genre-specification classifier (cli.py genre-classify) ---
# Claude model used to assign genre/subgenre/energy/vibe. Swappable for A/B.
CLASSIFIER_MODEL=claude-haiku-4-5

# Numeric audio features come from ReccoBeats (free; no key needed today). The
# defaults below are correct — only override to point elsewhere, or set a key if
# ReccoBeats starts requiring one. NEVER use Spotify audio-features (deprecated).
RECCOBEATS_BASE_URL=https://api.reccobeats.com
# RECCOBEATS_API_KEY=
DEEZER_BASE_URL=https://api.deezer.com

# Path to the editable classification taxonomy (allowed genres/subgenres/etc).
# TAXONOMY_PATH=taxonomy.json
